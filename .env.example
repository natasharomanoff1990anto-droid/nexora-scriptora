# ─────────────────────────────────────────────────────────────
# Nexora — example environment variables
# Copy to .env and fill in values. Missing vars block the app at boot
# (intentional — we never want silent fallback to a wrong backend).
#
# RULES:
# - VITE_*  → safe to expose to the browser bundle.
# - Anything else (DEEPSEEK_API_KEY, GEMINI_API_KEY, …) is server-only:
#   put it in Supabase Edge Function secrets, NEVER in this file.
# ─────────────────────────────────────────────────────────────

# ─── Your Supabase project (REQUIRED) ────────────────────────
VITE_SUPABASE_PROJECT_ID="lesxmntzrwjaooacvpko"
VITE_SUPABASE_URL="https://lesxmntzrwjaooacvpko.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="INSERIRE_CHIAVE_PUBBLICABILE"
VITE_SUPABASE_ANON_KEY="INSERIRE_CHIAVE_PUBBLICABILE"

# ─── App identity / build metadata (optional) ────────────────
VITE_APP_VERSION="1.0.0"
VITE_BUILD_CHANNEL="stable"

# ─── Feature flags (optional, default off) ───────────────────
VITE_AI_PROVIDER="deepseek"
VITE_ENABLE_GEMINI="false"

VITE_ENABLE_PAYMENTS="false"
VITE_PAYMENT_MODE="coming_soon"
VITE_PAYMENT_PROVIDER="none"
VITE_PAYMENT_MONTHLY_URL=""
VITE_PAYMENT_YEARLY_URL=""
VITE_PAYMENT_LIFETIME_URL=""
VITE_PAYMENT_SUCCESS_URL="/dashboard?payment=success"
VITE_PAYMENT_CANCEL_URL="/pricing?payment=cancelled"

VITE_ENABLE_DOWNLOADS="false"
VITE_DOWNLOAD_MODE="coming_soon"
VITE_ANDROID_APK_URL=""
VITE_ANDROID_AAB_URL=""
VITE_MAC_DMG_URL=""
VITE_MAC_ZIP_URL=""
VITE_WINDOWS_EXE_URL=""

# ─────────────────────────────────────────────────────────────
# SERVER-ONLY SECRETS (set with `supabase secrets set ...`,
# DO NOT put them in this file or anywhere in the frontend):
#   DEEPSEEK_API_KEY        ← required for AI generation
#   BRAVE_SEARCH_API_KEY    ← optional, market research
#   SUPABASE_SERVICE_ROLE_KEY ← auto, never expose
# ─────────────────────────────────────────────────────────────
